# Copy to .env.local and fill in. Never commit real secrets.

# --- Firebase (Web SDK — these are exposed to the browser when prefixed NEXT_PUBLIC_) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
# Optional: Realtime Database URL if you use it
# NEXT_PUBLIC_FIREBASE_DATABASE_URL=

# --- Google Maps Platform (restrict in Google Cloud Console) ---
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=

# --- Google Gemini (server-only) ---
GEMINI_API_KEY=

# --- reCAPTCHA v3 (optional — omit site key to skip widget in dev) ---
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
# Set to "true" to require token + /api/verify-recaptcha (default: bypass verification; footer can still show if site key is set)
# NEXT_PUBLIC_RECAPTCHA_ENFORCE=true
# Optional numeric threshold for /api/verify-recaptcha
# RECAPTCHA_MIN_SCORE=0.5
