{
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "target": "ES6",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"],
      "@/components/*": ["./presentation/components/*"],
      "@/hooks/*": ["./presentation/hooks/*"],
      "@/presentation/*": ["./presentation/*"],
      "@/firebase": ["./data/firebase.ts"],
      "@/lib/utils": ["./presentation/lib/utils.ts"],
      "@/lib/validation": ["./domain/validation.ts"],
      "@/lib/voice-routes": ["./domain/voice-routes.ts"],
      "@/lib/help-qa-data": ["./domain/help-qa-data.ts"],
      "@/lib/countries-data": ["./domain/countries-data.ts"],
      "@/lib/deals-data": ["./domain/deals-data.ts"],
      "@/lib/data": ["./domain/reviews-stub.ts"],
      "@/lib/schemas/*": ["./domain/schemas/*"],
      "@/lib/firestore/*": ["./data/firestore/*"],
      "@/lib/business-portal": ["./data/business-portal/index.ts"],
      "@/lib/places": ["./data/places/index.ts"],
      "@/lib/server/*": ["./data/server/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
